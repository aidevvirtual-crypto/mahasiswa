---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { db } from '../../db';
import { registrations, users } from '../../db/schema';
import { eq, desc, count } from 'drizzle-orm';

const user = Astro.locals.user;

// Fetch stats
const allRegistrations = await db.select().from(registrations);
const total = allRegistrations.length;
const pending = allRegistrations.filter(r => r.status === 'pending').length;
const approved = allRegistrations.filter(r => r.status === 'approved').length;
const rejected = allRegistrations.filter(r => r.status === 'rejected').length;

// Fetch recent registrations with user info
const recentRegs = await db.select({
  id: registrations.id,
  status: registrations.status,
  registrationType: registrations.registrationType,
  submittedAt: registrations.submittedAt,
  createdAt: registrations.createdAt,
  userName: users.name,
  userEmail: users.email
})
.from(registrations)
.leftJoin(users, eq(registrations.userId, users.id))
.orderBy(desc(registrations.createdAt))
.limit(10);

const stats = { total, pending, approved, rejected };
---

<BaseLayout title="Admin Dashboard | Mahasiswa">
  <div class="admin-layout">
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <svg width="36" height="36" viewBox="0 0 48 48" fill="none">
            <rect width="48" height="48" rx="12" fill="#1A365D"/>
            <path d="M24 12L36 18V30L24 36L12 30V18L24 12Z" stroke="white" stroke-width="2" fill="none"/>
            <circle cx="24" cy="24" r="6" fill="#D4AF37"/>
          </svg>
        </div>
        <span class="logo-text">Admin</span>
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="nav-item active">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/>
            <rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/>
          </svg>
          <span>Dashboard</span>
        </a>
        <a href="/admin/registrations" class="nav-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <span>Registrations</span>
        </a>
      </nav>
      
      <div class="sidebar-footer">
        <a href="/api/admin/logout" class="nav-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          <span>Logout</span>
        </a>
      </div>
    </aside>
    
    <main class="main-content">
      <header class="content-header">
        <div class="header-left">
          <h1>Dashboard</h1>
          <p>Welcome back, {user?.name || 'Admin'}</p>
        </div>
      </header>
      
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon total">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div class="stat-content">
            <span class="stat-value">{stats.total}</span>
            <span class="stat-label">Total Applications</span>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon pending">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="stat-content">
            <span class="stat-value">{stats.pending}</span>
            <span class="stat-label">Pending Review</span>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon approved">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <div class="stat-content">
            <span class="stat-value">{stats.approved}</span>
            <span class="stat-label">Approved</span>
          </div>
        </div>
        
        <div class="stat-card">
          <div class="stat-icon rejected">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="15" y1="9" x2="9" y2="15"/>
              <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
          </div>
          <div class="stat-content">
            <span class="stat-value">{stats.rejected}</span>
            <span class="stat-label">Rejected</span>
          </div>
        </div>
      </div>
      
      <section class="recent-section">
        <div class="section-header">
          <h2>Recent Applications</h2>
          <a href="/admin/registrations" class="view-all">View All</a>
        </div>
        
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Applicant</th>
                <th>Type</th>
                <th>Status</th>
                <th>Submitted</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="applications-table">
              {recentRegs.length === 0 ? (
                <tr class="empty-state">
                  <td colspan="5">
                    <div class="empty-content">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                      </svg>
                      <p>No applications yet</p>
                    </div>
                  </td>
                </tr>
              ) : (
                recentRegs.map(reg => (
                  <tr>
                    <td>
                      <div class="applicant-cell">
                        <span class="applicant-name">{reg.userName || 'Unknown'}</span>
                        <span class="applicant-email">{reg.userEmail || '-'}</span>
                      </div>
                    </td>
                    <td class="capitalize">{reg.registrationType || '-'}</td>
                    <td>
                      <span class={`badge badge-${reg.status}`}>{reg.status}</span>
                    </td>
                    <td>{reg.submittedAt ? new Date(reg.submittedAt).toLocaleDateString() : '-'}</td>
                    <td>
                      <a href={`/admin/registrations/${reg.id}`} class="action-btn">View</a>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .admin-layout {
    display: flex;
    min-height: 100vh;
  }

  .sidebar {
    width: 260px;
    background: var(--color-surface);
    border-right: 1px solid var(--color-outline-variant);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 100;
  }

  @media (max-width: 900px) {
    .sidebar {
      display: none;
    }
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px;
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-primary);
  }

  .sidebar-nav {
    flex: 1;
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    font-weight: 500;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .nav-item:hover {
    background: var(--color-surface-container);
    color: var(--color-text);
  }

  .nav-item.active {
    background: rgba(26, 54, 93, 0.1);
    color: var(--color-primary);
  }

  .sidebar-footer {
    padding: 12px;
    border-top: 1px solid var(--color-outline-variant);
  }

  .main-content {
    flex: 1;
    margin-left: 260px;
    background: var(--color-background);
    padding: 32px;
  }

  @media (max-width: 900px) {
    .main-content {
      margin-left: 0;
      padding: 20px;
    }
  }

  .content-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
  }

  .content-header h1 {
    font-size: 1.75rem;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .content-header p {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  @media (max-width: 1100px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  .stat-card {
    background: var(--color-surface);
    padding: 24px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: var(--shadow-sm);
  }

  .stat-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stat-icon.total {
    background: rgba(26, 54, 93, 0.1);
    color: var(--color-primary);
  }

  .stat-icon.pending {
    background: rgba(212, 175, 55, 0.1);
    color: var(--color-secondary-dark);
  }

  .stat-icon.approved {
    background: rgba(47, 133, 90, 0.1);
    color: var(--color-success);
  }

  .stat-icon.rejected {
    background: rgba(186, 26, 26, 0.1);
    color: var(--color-error);
  }

  .stat-value {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-top: 4px;
  }

  .recent-section {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 24px;
    box-shadow: var(--shadow-sm);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .section-header h2 {
    font-size: 1.125rem;
    color: var(--color-text);
  }

  .view-all {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .table-container {
    overflow-x: auto;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th,
  .data-table td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .data-table th {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .data-table td {
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .capitalize {
    text-transform: capitalize;
  }

  .applicant-cell {
    display: flex;
    flex-direction: column;
  }

  .applicant-name {
    font-weight: 500;
  }

  .applicant-email {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .empty-state td {
    padding: 48px;
  }

  .empty-content {
    text-align: center;
    color: var(--color-text-secondary);
  }

  .empty-content svg {
    margin-bottom: 16px;
    opacity: 0.5;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: capitalize;
  }

  .badge-pending {
    background: rgba(212, 175, 55, 0.1);
    color: var(--color-secondary-dark);
  }

  .badge-approved {
    background: rgba(47, 133, 90, 0.1);
    color: var(--color-success);
  }

  .badge-rejected {
    background: rgba(186, 26, 26, 0.1);
    color: var(--color-error);
  }

  .action-btn {
    padding: 6px 12px;
    font-size: 0.8125rem;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-outline-variant);
    cursor: pointer;
    text-decoration: none;
  }

  .action-btn:hover {
    background: var(--color-surface-container);
  }
</style>